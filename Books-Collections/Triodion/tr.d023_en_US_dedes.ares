trMA.Ode1C21.melody = he.h.m2_en_US_dedes.heHE.DefteLaoi.notmetered
trMA.Ode1C21.incipit = "O peoples, come and let…"
trMA.Ode1C21.text = "O peoples, come and let us welcome today the gift of Lent, as a God-given season of repentance; and during it, let us seek the Savior’s forgiveness."

