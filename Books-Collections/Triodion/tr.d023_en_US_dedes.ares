trVE.Stichera01.poet = poets_en_US_dedes.po.KyriouIosif
trVE.Stichera01.mode = miscellanea_en_US_dedes.misc.Mode2
trVE.Stichera01.melody = miscellanea_en_US_dedes.misc.NotMetered
trVE.Stichera01.incipit = "We are entering the godly…"
trVE.Stichera01.text = "We are entering the godly contest of the blameless Fast. Let us all diligently subdue the flesh through self-control. Let us seek the Lord with prayers and tears, and completely obliterate every vice, and shout to Him: “We have sinned against You. Save us, as You saved the Ninevites of old, O Christ our King. Grant us to share in Your heavenly Kingdom, O compassionate Lord.”"

trVE.Stichera02.mode = miscellanea_en_US_dedes.misc.Mode2
trVE.Stichera02.melody = miscellanea_en_US_dedes.misc.NotMetered
trVE.Stichera02.incipit = "I drive myself to despair…"
trVE.Stichera02.text = "I drive myself to despair, when I consider how my deeds are worthy of every punishment, O Savior. Yes, I have ignored Your divine commandments, and wasted my life as a profligate. Therefore I implore You the only merciful Lord: Purify me with tears of repentance, and illumine me by fasting and prayer, and do not abhor me, for You are very good and the Benefactor of all."

trVE.Stichera03.mode = miscellanea_en_US_dedes.misc.Mode2
trVE.Stichera03.melody = miscellanea_en_US_dedes.misc.NotMetered
trVE.Stichera03.incipit = "Let us cheerfully begin the…"
trVE.Stichera03.text = "Let us cheerfully begin the season of Lent, and undergo the spiritual struggles. Let us purify and cleanse our souls and bodies. As we fast from foods, let us also abstain from giving in to any of the passions, and instead delight in the virtues of the Spirit. May we persevere in them with love, and then be counted worthy to see the solemn Passion of Christ our God, and to celebrate holy Pascha with spiritual joy."

trVE.AposIdiomelon1.mode = miscellanea_en_US_dedes.misc.Mode4
trVE.AposIdiomelon1.melody = miscellanea_en_US_dedes.misc.Idiomelon
trVE.AposIdiomelon1.incipit = "Your grace has shone forth…"
trVE.AposIdiomelon1.text = "Your grace has shone forth, O Lord; the illumination of our souls has shone forth. Behold, this is the acceptable season; behold, this is the season of repentance. Let us put away the works of darkness, and put on the armor of light, so that we may navigate the immense ocean of Lent, and arrive at the third-day Resurrection of our Lord and Savior Jesus Christ, the Savior of our souls."

trVE.AposMartyric.mode = miscellanea_en_US_dedes.misc.Mode4
trVE.AposMartyric.melody = ""
trVE.AposMartyric.incipit = "O Christ our God, You…"
trVE.AposMartyric.text = "O Christ our God, You are glorified when we commemorate Your saints. As they implore You on our behalf, send down to us Your great mercy."

trVE.AposTheotokion.mode = miscellanea_en_US_dedes.misc.Mode4
trVE.AposTheotokion.greekmelody = he.a.m4_en_US_dedes.heAU.OsGennaionEnMartysi.greekname
trVE.AposTheotokion.melody = he.a.m4_en_US_dedes.heAU.OsGennaionEnMartysi.name
trVE.AposTheotokion.incipit = "All the ranks of angelic…"
trVE.AposTheotokion.text = "All the ranks of angelic hosts glorify you, O Bride of God. * You, O Theotokos, gave birth to God the Word, * who with the Father and Spirit is existing eternally. * He created all the hosts * of the Angels ex nihilo, * by His will as God. * All-pure Virgin, now pray that He illuminate our souls and that He save us, * who are correctly extolling you."

