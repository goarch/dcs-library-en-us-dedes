trMA.Ode1C1T.incipit = "O Maiden, who gave birth…"
trMA.Ode1C1T.text = "O Maiden, who gave birth to the source of dispassion, heal me who am wounded by the passions, and snatch me from the eternal fire, O Lady grace by God."

