trMA.Kontakion0.mode = miscellanea_en_US_dedes.misc.Mode4
trMA.Kontakion0.melody = he.a.m4_en_US_dedes.heAU.EpefanisSimeron.name
trMA.Kontakion0.incipit = "Let us flee the Pharisee’s…"
trMA.Kontakion0.text = "Let us flee the Pharisee’s * exalted parlance; * let us learn the Publican’s * humble demeanor, and with sighs * unto the Savior cry out and say, * To us be gracious, O only forgiving Lord."

trMA.Kontakion1.mode = miscellanea_en_US_dedes.misc.Mode3
trMA.Kontakion1.melody = he.a.m3_en_US_dedes.heAU.IParthenosSimeron.name
trMA.Kontakion1.incipit = "Sinners, let us fall before…"
trMA.Kontakion1.text = "Sinners, let us fall before * the Lord and Master in prayer, * and as once the Publican * let us present Him our sighing. * He desires that all humanity gain salvation. * And to all who are repentant He grants forgiveness. * He became a man for our sake, * though with the Father without beginning as God."

trMA.Oikos1.text = "Brethren, let us all garb ourselves in lowliness, and with laments and sighs strike at our conscience, that at the judgment then, which is in perpetuity, we shall be viewed guiltless, attaining our impunity. For there we have true mitigation; to see it, let us make supplication. For there is pain and sorrow’s unseating, gone the deep sighs, there in wondrous Eden, of which Christ was fashioner, He being with the Father without beginning as God."

trSY.commemoration.text = "On this day, we remember the parable of the Publican and the Pharisee from the holy Gospel of the Evangelist Luke (18:10-14)."
trSY.commemoration.couplet1.title = titles_en_US_dedes.ti.Verses
trSY.commemoration.couplet1.verse1 = "Pharisaical man, stay away from the Temple,"
trSY.commemoration.couplet1.verse2 = "for Christ is therein, where He accepts the humble."
trSY.commemoration.couplet2.title = "For the Triodion"
trSY.commemoration.couplet2.verse1 = "O Creator of all in earth and in heaven,"
trSY.commemoration.couplet2.verse2 = "As You receive the thrice-holy hymn from the Angels,"
trSY.commemoration.couplet2.verse3 = "So also accept the Triodion from us humans."
trSY.commemoration.narration.p01 = "[paragraph 01]"
trSY.commemoration.narration.p02 = "[paragraph 02]"
trSY.commemoration.narration.p03 = "[paragraph 03]"
trSY.commemoration.narration.p04 = "[paragraph 04]"
trSY.commemoration.narration.p05 = "[paragraph 05]"
trSY.commemoration.narration.p06 = "[paragraph 06]"
trSY.commemoration.narration.p07 = "[paragraph 07]"
trSY.lastline = "By the intercessions of all Your Saints, who have done great things, O Christ our God, have mercy on us and save us. Amen."

