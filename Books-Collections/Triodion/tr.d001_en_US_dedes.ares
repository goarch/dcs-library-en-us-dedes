trMA.Exaposteilarion1.mode = miscellanea_en_US_dedes.misc.Mode2
trMA.Exaposteilarion1.greekmelody = he.a.m2_en_US_dedes.heAU.ToisMathitaisSynelthomen.greekname
trMA.Exaposteilarion1.melody = he.a.m2_en_US_dedes.heAU.ToisMathitaisSynelthomen.name
trMA.Exaposteilarion1.incipit = "Let us all flee the…"
trMA.Exaposteilarion1.text = "Let us all flee the Pharisee’s * abusive ostentation, * and rather learn the Publican’s * excellent self-abasement, * so that we too be exalted,* crying to God like he did, * Be gracious to Your servants, Lord * voluntarily born of a Virgin Maid, * Christ our Savior who endured crucifixion, * and with yourself raised up Your world, * by Your divine dominion."

trMA.ExapTheotokion.mode = miscellanea_en_US_dedes.misc.Mode2
trMA.ExapTheotokion.greekmelody = he.a.m2_en_US_dedes.heAU.ToisMathitaisSynelthomen.greekname
trMA.ExapTheotokion.melody = he.a.m2_en_US_dedes.heAU.ToisMathitaisSynelthomen.name
trMA.ExapTheotokion.incipit = "The God of all the…"
trMA.ExapTheotokion.text = "The God of all the universe * and Maker of creation * assumed our mortal human flesh * from your unsullied womb, O all-laudable Theotokos, * and my corrupted nature * He made completely new again. * After His birth He left you as you had been * before giving birth to Him. Hence we cry out * with faith extolling you, Rejoice, * the universe’s glory."

