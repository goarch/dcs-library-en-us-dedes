trVE.AposTheotokion.incipit = oc.m5.d1_en_US_dedes.ocVE.AposTheotokion.incipit
trVE.AposTheotokion.text = oc.m5.d1_en_US_dedes.ocVE.AposTheotokion.text

trMA.PostGospelGlory.mode = miscellanea_en_US_dedes.misc.Mode8
trMA.PostGospelGlory.melody = ""
trMA.PostGospelGlory.incipit = "Open to me the gates…"
trMA.PostGospelGlory.text = "Open to me the gates of repentance, O Giver of Life, for early in the morning my spirit hastens to Your holy temple, bringing the temple of my body all defiled. But as one compassionate, cleanse me, I pray, by Your loving-kindness and mercy."

trMA.PostGospelBoth.mode = miscellanea_en_US_dedes.misc.Mode8
trMA.PostGospelBoth.melody = ""
trMA.PostGospelBoth.incipit = "Guide me in the paths…"
trMA.PostGospelBoth.text = "Guide me in the paths of salvation, O Theotokos, for I have befouled my soul with shameful sins and I heedlessly squandered all of my life’s resources. By your intercession deliver me from every uncleanness."

trMA.PostGospelIdiomelon.mode = miscellanea_en_US_dedes.misc.Mode6
trMA.PostGospelIdiomelon.melody = ""
trMA.PostGospelIdiomelon.incipit = "When I ponder in my…"
trMA.PostGospelIdiomelon.text = "When I ponder in my wretchedness on the many terrible things that I have done, I tremble for that fearful day, the Day of Judgment. But trusting in the mercy of Your compassion, like David I cry to You, “Have mercy on me, O God, according to Your great mercy.”"

