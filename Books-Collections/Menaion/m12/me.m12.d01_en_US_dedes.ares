meVE.SticTheotokion.mode = miscellanea_en_US_dedes.misc.Mode3
meVE.SticTheotokion.greekmelody = he.a.m3_en_US_dedes.heAU.MegaliTouStavrouSou.greekname
meVE.SticTheotokion.melody = he.a.m3_en_US_dedes.heAU.MegaliTouStavrouSou.name
meVE.SticTheotokion.incipit = "Through you, O all-pure Virgin…"
meVE.SticTheotokion.text = "Through you, O all-pure Virgin, we received great benefit. * And now we join the Prophets * in honoring your childbirth. * Your Son and God accepted to be carried in your body, * in His supreme compassion, * and to regenerate the human race, O Lady."

meVE.SticStavrotheotokion.mode = miscellanea_en_US_dedes.misc.Mode3
meVE.SticStavrotheotokion.greekmelody = he.a.m3_en_US_dedes.heAU.MegaliTouStavrouSou.greekname
meVE.SticStavrotheotokion.melody = he.a.m3_en_US_dedes.heAU.MegaliTouStavrouSou.name
meVE.SticStavrotheotokion.incipit = "All-blameless Lady, when you saw…"
meVE.SticStavrotheotokion.text = "All-blameless Lady, when you saw the Son whom you had borne * crucified and not breathing, * with bitter grief you cried out, * “Most beloved Child, tell me, how could Your handsome beauty * set like the sun, voluntarily * hiding behind the cloud of death?”"

