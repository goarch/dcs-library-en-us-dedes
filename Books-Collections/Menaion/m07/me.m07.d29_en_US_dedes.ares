meVE.Stichera04.mode = miscellanea_en_US_dedes.misc.Mode4
meVE.Stichera04.greekmelody = he.a.m4_en_US_dedes.heAU.OsGennaionEnMartysi.greekname
meVE.Stichera04.melody = he.a.m4_en_US_dedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera04.incipit = "Theodota, we honor you *…"
meVE.Stichera04.text = "Theodota, we honor you * as a virgin and Martyr Saint, * as a bride of God who preserved her chastity, * as one who shone with the Spirit’s grace, * adoring and loving Christ, * while embarrassing the foe, * by competing unflinchingly and enduring all * pain and torture. And therefore we extol you, and with faith we keep your saving * and most illustrious memory."

meVE.Stichera05.mode = miscellanea_en_US_dedes.misc.Mode4
meVE.Stichera05.melody = he.a.m4_en_US_dedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera05.incipit = "By your faith you became…"
meVE.Stichera05.text = "By your faith you became a bride, * in the Spirit, for Christ our God, * bringing as a dowry the torture you endured: * the grueling labors of martyrdom, * the burning of all your limbs, * the excruciating pain, * the prolonged brutal agony, and your bleeding out. * And for this you were crowned and granted entry to the godly bridal chamber, * praying for all those who honor you."

meVE.Stichera06.mode = miscellanea_en_US_dedes.misc.Mode4
meVE.Stichera06.melody = he.a.m4_en_US_dedes.heAU.OsGennaionEnMartysi.name
meVE.Stichera06.incipit = "Theodota, we honor you *…"
meVE.Stichera06.text = "Theodota, we honor you * as one brave and unwavering. * Godly-minded Martyr, you utterly destroyed * the devil’s wicked deceptiveness, * with valorous frame of mind * trampling him who battered Eve. * You departed for the expanse * there in Paradise. * Now, O glorious Saint, we all extol you, for by your participation * in grace divine you were deified."

