meMA.Exaposteilarion1.mode = miscellanea_en_US_dedes.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_en_US_dedes.heAU.EpeskepsatoImas.greekname
meMA.Exaposteilarion1.melody = he.a.m3_en_US_dedes.heAU.EpeskepsatoImas.name
meMA.Exaposteilarion1.incipit = "Alive in the living God…"
meMA.Exaposteilarion1.text = "Alive in the living God, * even in death your blood poured out * in streams of life-giving perfume. * And you were granted to become * an heir of His new covenant. * Theodota, you guard us, * who lovingly sing your praise."

meMA.ExapTheotokion.mode = miscellanea_en_US_dedes.misc.Mode3
meMA.ExapTheotokion.melody = he.a.m3_en_US_dedes.heAU.EpeskepsatoImas.name
meMA.ExapTheotokion.incipit = "Good Lady, wider than heaven…"
meMA.ExapTheotokion.text = "Good Lady, wider than heaven, * though you were carried to its heights, * do not abandon or forsake * your servants who are still on earth. * Stretch our your hands and intercede * with the merciful Master * on behalf of all the world."

