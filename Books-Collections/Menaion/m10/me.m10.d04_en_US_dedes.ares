meMA.Ode9H.text = he.h.m8_en_US_dedes.heHE.ExestiEpiTouto.text

meMA.Exaposteilarion1.mode = miscellanea_en_US_dedes.misc.Mode3
meMA.Exaposteilarion1.greekmelody = he.a.m3_en_US_dedes.heAU.OOuranonToisAstrois.greekname
meMA.Exaposteilarion1.melody = he.a.m3_en_US_dedes.heAU.OOuranonToisAstrois.name
meMA.Exaposteilarion1.incipit = "When the Mother of the…"
meMA.Exaposteilarion1.text = "When the Mother of the Logos * was about to be translated * to her repose there in heaven, * O Hierotheos, you came * with the rest of the Apostles, * escorting her with sublime hymns."

