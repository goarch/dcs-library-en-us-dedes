A_Resource_Whose_Name = me.m10.d04_en_US_dedes

meDA.date = "October 4"
meDA.commemoration.full = "Memory of our Father among the Saints Hierotheos, Bishop of Athens" //full title of day
meDA.commemoration.first = "Memory of our Father among the Saints Hierotheos"
meDA.commemoration.first_short = "Memory of our Father among the Saints Hierotheos"
meDA.commemoration.first_title = titles_en_US_dedes.ti.SaintM
meDA.commemoration.first_name = ""
meDA.commemoration.second_title = ""
meDA.commemoration.second_name = ""
meDA.insert1 = "and our father among the saints, Hierotheos, bishop of Athens," //for use in petitions and dismissal
meDA.insert2 = "whose memory we observe," //for use in petitions and dismissal
meDA.note = ""
meDA.pdfcoverdate = "October 4,"
meDA.pdfdatebefore = "October 3"
meDA.pdfheaderdate = "October 4"
meDA.fordate = "for October 4,"
