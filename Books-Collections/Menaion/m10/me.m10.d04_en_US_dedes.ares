meVE.Stichera01.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.Stichera01.greekmelody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.greekname
meVE.Stichera01.melody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.name
meVE.Stichera01.incipit = "The eros of Christ, which…"
meVE.Stichera01.text = "The eros of Christ, which is indeed * most divine and in the form of light, illumined your soul and with its sweetest radiance * fired up your thinking * towards the truth and godliness, and being fire totally burned away all pleasure of the flesh, * and it made you a most hon’rable * precious vessel * of illumination from on high."

meVE.Stichera02.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.Stichera02.melody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.name
meVE.Stichera02.incipit = "O blessed Hierotheos, your words’…"
meVE.Stichera02.text = "O blessed Hierotheos, your words’ * grandeur and magnificence, and your astute explanations’ most concordant and precise * systematic method * are the product of a scientific disposition that seeks the truth; and all acknowledge this. * They enlighten those who study them * and give knowledge * to those who love reading them."

meVE.Stichera03.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.Stichera03.melody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.name
meVE.Stichera03.incipit = "O blessed Hierotheos, indeed…"
meVE.Stichera03.text = "O blessed Hierotheos, indeed * holy Dionysius, who was adept in theology, related what he learned * from you to the faithful, * and he published your now famous essays on divine visions and your dogmas that are most sublime. * Pray together that surpassing peace * and great mercy * be upon our souls bestowed."

meVE.SticTheotokion.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.SticTheotokion.greekmelody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.greekname
meVE.SticTheotokion.melody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.name
meVE.SticTheotokion.incipit = "All-laudable Virgin…"
meVE.SticTheotokion.text = "All-laudable Virgin, Moses saw * with his own prophetic eyes of old the mystery wrought in you when he beheld the bush * unconsumed though burning. * For in you the fire of Divinity in no way consumed your womb. And therefore we entreat * you, O pure one, Mother of our God, * grant your servants * the mercy and peace of Christ." //similar to oc.m1.d3.ocMA.AposTheotokion.text"

meVE.SticStavrotheotokion.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.SticStavrotheotokion.greekmelody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.greekname
meVE.SticStavrotheotokion.melody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.name
meVE.SticStavrotheotokion.incipit = oc.m1.d4_en_US_dedes.ocVE.SticTheotokion.incipit
meVE.SticStavrotheotokion.text = oc.m1.d4_en_US_dedes.ocVE.SticTheotokion.text

meVE.Apolytikion1ger.poet = poets_en_US_dedes.po.Gerasimou
