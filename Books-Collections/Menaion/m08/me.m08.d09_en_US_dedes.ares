meMA.Exaposteilarion1.text = "Judas the lawless and profane * willfully broke allegiance, * and on his own he broke away * from the divine twelve member council of sacred Apostles. * Then by divine election * the all-extolled Matthias was * chosen as a Disciple by casting lots, * to be an Apostle of Christ, to give light * to all the world with the divine * Holy Trinity’s doctrines."

meMA.Exaposteilarion2.mode = miscellanea_en_US_dedes.misc.Mode2
meMA.Exaposteilarion2.greekmelody = he.a.m2_en_US_dedes.heAU.ToisMathitaisSynelthomen.greekname
meMA.Exaposteilarion2.melody = he.a.m2_en_US_dedes.heAU.ToisMathitaisSynelthomen.name
meMA.Exaposteilarion2.incipit = me.m08.d07_en_US_dedes.meMA.Exaposteilarion2.incipit
meMA.Exaposteilarion2.text = me.m08.d07_en_US_dedes.meMA.Exaposteilarion2.text

meMA.Aposticha1.mode = miscellanea_en_US_dedes.misc.Mode2
meMA.Aposticha1.greekmelody = he.a.m2_en_US_dedes.heAU.OikosTouEfratha.greekname
meMA.Aposticha1.melody = he.a.m2_en_US_dedes.heAU.OikosTouEfratha.name
meMA.Aposticha1.incipit = "Savior exceeding good, * when…"
meMA.Aposticha1.text = "Savior exceeding good, * when You were on Mount Tabor * transfigured, Your disciples * beheld and knew the glory of the all-holy Trinity."

meMA.Aposticha2.mode = miscellanea_en_US_dedes.misc.Mode2
meMA.Aposticha2.melody = he.a.m2_en_US_dedes.heAU.OikosTouEfratha.name
meMA.Aposticha2.incipit = "When the bright shining cloud…"
meMA.Aposticha2.text = "When the bright shining cloud * at Your transfiguration * with brilliant light spread over * Your holy three disciples, it filled them with astonishment."

meMA.Aposticha3.mode = miscellanea_en_US_dedes.misc.Mode2
meMA.Aposticha3.melody = he.a.m2_en_US_dedes.heAU.OikosTouEfratha.name
meMA.Aposticha3.incipit = "Standing with You, O Word…"
meMA.Aposticha3.text = "Standing with You, O Word, * at Your transfiguration, * were Moses and Elias. * The Father spoke from heaven and called You His beloved Son."

meMA.AposGlory.mode = miscellanea_en_US_dedes.misc.Mode2
meMA.AposGlory.melody = he.a.m2_en_US_dedes.heAU.OikosTouEfratha.name
meMA.AposGlory.incipit = me.m08.d07_en_US_dedes.meVE.Aposticha2.incipit
meMA.AposGlory.text = me.m08.d07_en_US_dedes.meVE.Aposticha2.text

meLI.Megalynarion.text = "Apostle Matthias, we honor you * the divine instructor of the true faith, and we extol * you, who filled the twelfth seat of the chosen Disciples, * excellent intercessor for us unto the Lord."
