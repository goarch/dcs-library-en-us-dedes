meVE.AposGlory.mode = miscellanea_en_US_dedes.misc.Mode8
meVE.AposGlory.melody = ""
meVE.AposGlory.incipit = "We the multitudes of monastics…"
meVE.AposGlory.text = "We the multitudes of monastics honor you, devout Chariton, as our teacher and guide. For through you we have learned to walk the truly straight and narrow path. Blessed are you, who served Christ and triumphed over the power of the enemy. As you consort now with the Angels and dwell with the Devout and Righteous, pray with them to the Lord, that He have mercy on our souls."

meVE.AposTheotokion.mode = miscellanea_en_US_dedes.misc.Mode8
meVE.AposTheotokion.greekmelody = he.a.m8_en_US_dedes.heAU.OTouParadoxou.greekname
meVE.AposTheotokion.melody = he.a.m8_en_US_dedes.heAU.OTouParadoxou.name
meVE.AposTheotokion.incipit = "Lady, we salute and sing…"
meVE.AposTheotokion.text = "Lady, we salute and sing, “Rejoice!” * You care for those who believe, * offer refuge for those who sinned, * and correct the negligent. * You refresh and assist the distressed. * A kind consoler of souls are you. Rejoice! * You are the healer of souls that are infirm. * You are our guarantor, * interceding as you do with God for us. * Rejoice! You are holier than all the Seraphim."

meVE.AposStavrotheotokion.mode = miscellanea_en_US_dedes.misc.Mode8
meVE.AposStavrotheotokion.greekmelody = he.a.m8_en_US_dedes.heAU.OTouParadoxou.greekname
meVE.AposStavrotheotokion.melody = he.a.m8_en_US_dedes.heAU.OTouParadoxou.name
meVE.AposStavrotheotokion.incipit = "What is this spectacle…"
meVE.AposStavrotheotokion.text = "“What is this spectacle that I see with my own eyes, O my Son * who created the universe? * You who hold creation all * in Your hand have been crucified! * You who give life to all living things have died!” * So did the Mother of God cry out and say, * as she was watching You * being lifted on the Cross, who had shone forth * from her womb ineffably, being both God and man."

