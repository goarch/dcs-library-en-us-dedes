meMA.Kontakion1.mode = miscellanea_en_US_dedes.misc.Mode2
meMA.Kontakion1.greekmelody = he.a.m2_en_US_dedes.heAU.TousAsfaleis.greekname
meMA.Kontakion1.melody = he.a.m2_en_US_dedes.heAU.TousAsfaleis.notmetered
meMA.Kontakion1.incipit = "Today, O believers, let us…"
meMA.Kontakion1.text = "Today, O believers, let us all crown with hymns and extol with poems St. Chariton, the pastor and teacher and Martyr of Christ. He practiced self-control, and he competed for the sake of the Orthodox Faith. His name means Grace, and he is a universally acclaimed luminary of the world."

meMA.Oikos1.text = "O believers, let us sing hymns and extol that blessed man Chariton, the great monastic Saint and divine star of Iconium, and let us crown his head with divine songs. He demolished the pretentiousness of the useless idols, and likewise neutralized all their demonic power. Since he underwent the labors, he indeed also received the awards. And so we praise and honor him as a universally acclaimed luminary of the world."

