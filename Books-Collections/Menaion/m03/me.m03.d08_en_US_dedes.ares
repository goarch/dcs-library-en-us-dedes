meMA.Kontakion1ger.poet = poets_en_US_dedes.po.Gerasimou
meMA.Kontakion1ger.mode = miscellanea_en_US_dedes.misc.Mode2
meMA.Kontakion1ger.melody = he.a.m2_en_US_dedes.heAU.TousAsfaleis.notmetered
meMA.Kontakion1ger.incipit = "You were an unbreakable champion…"
meMA.Kontakion1ger.text = "You were an unbreakable champion of Orthodoxy, and a mighty rebuke of heresy. We sing to you and extol you, O holy Bishop Theophylact. From all evils protect us, who faithfully celebrate your memory, and intercede for the salvation of our souls."

