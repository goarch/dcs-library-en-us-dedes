meR001 = "Today we sing the service of the Holy Forty Martyrs (March 9) in advance, because this year their memory falls on the Saturday of the Souls."

meVE.Stichera01.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.Stichera01.greekmelody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.greekname
meVE.Stichera01.melody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.name
meVE.Stichera01.incipit = "When you were in prison…"
meVE.Stichera01.text = "When you were in prison under guard, * God protected you from injury, O Father Theophylact. To all you seemed to be * an unshaken tower * of the holy Church of Christ, not yielding to temptations or to the plots that heretics devised. * Will you pray now that surpassing peace * and great mercy be upon our souls bestowed."

meVE.Stichera02.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.Stichera02.melody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.name
meVE.Stichera02.incipit = "Transported from earth, you made…"
meVE.Stichera02.text = "Transported from earth, you made your way * into heaven, and you were accounted worthy to dwell in the celestial abodes, * being thus rewarded * for the exile you had bravely undergone for Christ God, O blessed Father, Saint Theophylact. * Will you pray now that surpassing peace * and great mercy be upon our souls bestowed."

meVE.Stichera03.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.Stichera03.melody = he.a.m1_en_US_dedes.heAU.PaneffimoiMartyres.name
meVE.Stichera03.incipit = "Rejoicing, all-blessed Hierarch, * you…"
meVE.Stichera03.text = "Rejoicing, all-blessed Hierarch, * you received that which alone is truly blest and desirable, O Saint Theophylact; * for you now are seeing * God as much as possible, and you are seen by Him, by a union that is better than before, * by adoption being deified. * Holy Father, * you dwell with the Angels on high."

