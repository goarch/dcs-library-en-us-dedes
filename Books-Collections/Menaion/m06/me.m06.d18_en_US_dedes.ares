meVE.SticTheotokion.mode = miscellanea_en_US_dedes.misc.Mode8
meVE.SticTheotokion.greekmelody = he.a.m8_en_US_dedes.heAU.TiYmasKalesomen.greekname
meVE.SticTheotokion.melody = he.a.m8_en_US_dedes.heAU.TiYmasKalesomen.name
meVE.SticTheotokion.incipit = "Wretched soul, to whom shall…"
meVE.SticTheotokion.text = "Wretched soul, to whom shall I liken you, * insubordinate and wholly unrepentant as you are, * and persistent in your vices, unafraid of hell and fire? * Arise now, cry out to the Mother of our God, * for only she can come to help you speedily, * “O Lady, cease not to intercede * with Christ, your Son and our God, I pray, * to rescue me * from the traps the devil lays for me.”"

meVE.SticStavrotheotokion.mode = miscellanea_en_US_dedes.misc.Mode8
meVE.SticStavrotheotokion.greekmelody = he.a.m8_en_US_dedes.heAU.TiYmasKalesomen.greekname
meVE.SticStavrotheotokion.melody = he.a.m8_en_US_dedes.heAU.TiYmasKalesomen.name
meVE.SticStavrotheotokion.incipit = "When the Virgin Mary, the…"
meVE.SticStavrotheotokion.text = "When the Virgin Mary, the Ewe, beheld * her own Son, the Lamb of God, nailed to the cross of His own will, * she lamented, as His mother, and she wept and cried aloud, * “My Child, what is this unheard of spectacle! * As Master, of the world You give all beings life. * How can You die, O forbearing Lord, who resurrects all humanity? * I glorify Your tremendous condescension, my God.”"

