meMA.Exaposteilarion1.mode = miscellanea_en_US_dedes.misc.Mode2
meMA.Exaposteilarion1.greekmelody = he.a.m2_en_US_dedes.heAU.GynaikesAkoutisthite.greekname
meMA.Exaposteilarion1.melody = he.a.m2_en_US_dedes.heAU.GynaikesAkoutisthite.name
meMA.Exaposteilarion1.incipit = "Bartholomew and Barnabas…"
meMA.Exaposteilarion1.text = "Bartholomew and Barnabas, * Apostles who were God-inspired, * today have there sacred feast day, * and we duty bound observe it. * So let us celebrate with joy * their splendid sacred memory. * As they are the Lord’s Disciples, * they intercede without ceasing * and pray for us who extol them."

meMA.ExapTheotokion.mode = miscellanea_en_US_dedes.misc.Mode2
meMA.ExapTheotokion.melody = he.a.m2_en_US_dedes.heAU.GynaikesAkoutisthite.name
meMA.ExapTheotokion.incipit = ho.ho03_en_US_dedes.hoMA.ExapThuTh.incipit
meMA.ExapTheotokion.text = ho.ho03_en_US_dedes.hoMA.ExapThuTh.text

meMA.Lauds1.mode = miscellanea_en_US_dedes.misc.Mode4
meMA.Lauds1.greekmelody = he.a.m4_en_US_dedes.heAU.OsGennaionEnMartysi.greekname
meMA.Lauds1.melody = he.a.m4_en_US_dedes.heAU.OsGennaionEnMartysi.name
meMA.Lauds1.incipit = "Our Lord Jesus…"
meMA.Lauds1.text = "Our Lord Jesus, the glorious * sun and Son of the living God, * sent you as a bright shining ray of brilliant light * to all the people throughout the world, * divine godly-minded Saint, * with the mission to drive out * all the darkness of wickedness, * and to bring the light * to the hearts that were darkened by the dominance of ignorance and passions, * blessed Apostle Bartholomew."

meMA.Lauds2.mode = miscellanea_en_US_dedes.misc.Mode4
meMA.Lauds2.melody = he.a.m4_en_US_dedes.heAU.OsGennaionEnMartysi.name
meMA.Lauds2.incipit = "You became a most pure…"
meMA.Lauds2.text = "You became a most pure and bright * dwelling place of the Trinity, * for you were adorned with the virtues’ brilliant light, * and in your heart you received therefrom * heavenly enlightenment, * and you radiate Its light, * which is brighter than any sun, O St. Barnabas, * to the ends of the earth, O God-inspired, * and illumined many people * who sat in the darkness of ignorance."

meMA.Lauds3.mode = miscellanea_en_US_dedes.misc.Mode4
meMA.Lauds3.melody = he.a.m4_en_US_dedes.heAU.OsGennaionEnMartysi.name
meMA.Lauds3.incipit = "As if clouds…"
meMA.Lauds3.text = "As if clouds, you, O blessed men, * showered down the celestial rain * upon on all the ends of the earth, and thus, O Saints, * you irrigated the souls of the believers with grace divine, * suffocating thorny weeds * of the absence of faith in God, * and you made the souls * of the people be spiritually fruitful; * and for this, holy Apostles, * with hymns of praise we now honor you."

meMA.LaudsGlory.mode = miscellanea_en_US_dedes.misc.Mode5
meMA.LaudsGlory.melody = ""
meMA.LaudsGlory.incipit = "As the Wisdom of God…"
meMA.LaudsGlory.text = "As the Wisdom of God, the co-eternal Logos of the Father, said of old in the Gospels, you, O all-praised Apostles, are fruitful vines, whose branches bear ripe and delicious grapes. When we the faithful eat of them, they leave a pleasing taste. O God-inspired Bartholomew, and Barnabas, the son of consolation, earnestly intercede on behalf of our souls."

meMA.LaudsTheotokion.mode = miscellanea_en_US_dedes.misc.Mode5
meMA.LaudsTheotokion.melody = ""
meMA.LaudsTheotokion.incipit = oc.m5.d3_en_US_dedes.ocVE.AposTheotokion.incipit
meMA.LaudsTheotokion.text = oc.m5.d3_en_US_dedes.ocVE.AposTheotokion.text

