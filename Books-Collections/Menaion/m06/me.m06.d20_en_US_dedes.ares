meVE.SticTheotokion.mode = miscellanea_en_US_dedes.misc.Mode8
meVE.SticTheotokion.greekmelody = he.a.m4_en_US_dedes.heAU.EdokasSimeiosin.greekname
meVE.SticTheotokion.melody = he.a.m4_en_US_dedes.heAU.EdokasSimeiosin.name
meVE.SticTheotokion.incipit = "Lady, I implore you now…"
meVE.SticTheotokion.text = "Lady, I implore you now, the cleanest Palace of God the King, * holy Virgin extolled by all. * Purify my intellect, soiled by my shameful * thoughts and sinful actions. Make it a dwelling that is bright * and a delight for the Holy Trinity. * And I your worthless servant, being by you rescued, shall magnify * and extol your commanding might and immeasurable tender love."

meVE.SticStavrotheotokion.mode = miscellanea_en_US_dedes.misc.Mode8
meVE.SticStavrotheotokion.greekmelody = he.a.m4_en_US_dedes.heAU.EdokasSimeiosin.greekname
meVE.SticStavrotheotokion.melody = he.a.m4_en_US_dedes.heAU.EdokasSimeiosin.name
meVE.SticStavrotheotokion.incipit = "When the all-pure Lady witnessed…"
meVE.SticStavrotheotokion.text = "When the all-pure Lady witnessed our benevolent Savior Christ * being crucified, and His side * was pierced with a spear, she wept. * Tearfully she cried out, * “How have these ungrateful people rewarded You, my Son, * for all the good things that You have done for them? * What is this, my beloved? Why the rush to render me childless? * I am stunned by Your willingness * to be crucified, glorious Lord.”"

meVE.Apolytikion1ger.poet = poets_en_US_dedes.po.Gerasimou
meVE.Apolytikion1ger.mode = miscellanea_en_US_dedes.misc.Mode3
meVE.Apolytikion1ger.greekmelody = he.a.m3_en_US_dedes.heAU.TheiasPisteos.greekname
meVE.Apolytikion1ger.melody = he.a.m3_en_US_dedes.heAU.TheiasPisteos.name
meVE.Apolytikion1ger.incipit = "O Methodius, your divine method…"
meVE.Apolytikion1ger.text = "O Methodius, your divine method * as a hierarch and martyr added * to the treasures and the wealth of the Church of Christ. * You took possession of wisdom as capital * and you increased it by means of your martyrdom. * Holy Father, pray earnestly to Christ our God, * entreating Him to grant us His great mercy."

