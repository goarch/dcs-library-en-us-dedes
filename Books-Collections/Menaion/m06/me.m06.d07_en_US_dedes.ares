meVE.Stichera01.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.Stichera01.greekmelody = he.a.m1_en_US_dedes.heAU.TonOuranionTagmaton.greekname
meVE.Stichera01.melody = he.a.m1_en_US_dedes.heAU.TonOuranionTagmaton.name
meVE.Stichera01.incipit = "You were awarded the medal…"
meVE.Stichera01.text = "You were awarded the medal, Martyr Theodotus, * for competing according * to the rules of the contests. * Indeed, with firm resolve and with joy in your heart, * you entered them of your own accord * and did not cower at all, for you did not fear * painful torture nor a violent death."

meVE.Stichera02.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.Stichera02.melody = he.a.m1_en_US_dedes.heAU.TonOuranionTagmaton.name
meVE.Stichera02.incipit = "The adversaries were wounded when…"
meVE.Stichera02.text = "The adversaries were wounded when you, O Martyr, endured * your body’s mutilation. * And when you criticized them, * it pulverized their hearts. And the river of blood * that you poured out in martyrdom * completely stopped the effusions of putrid pus * of ungodliness, O blessed Saint."

meVE.Stichera03.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.Stichera03.melody = he.a.m1_en_US_dedes.heAU.TonOuranionTagmaton.name
meVE.Stichera03.incipit = "With great endurance you suffered…"
meVE.Stichera03.text = "With great endurance you suffered as torches burned your flesh * and you were crushed and pummeled * in the face, holy Martyr. * With fortitude you bore all and cried aloud, * with conviction for all to hear, * “Nothing at all, neither torture, nor death, nor life * separates me from the love of Christ.”"

meVE.SticTheotokion.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.SticTheotokion.greekmelody = he.a.m1_en_US_dedes.heAU.TonOuranionTagmaton.greekname
meVE.SticTheotokion.melody = he.a.m1_en_US_dedes.heAU.TonOuranionTagmaton.melody
meVE.SticTheotokion.incipit = he.a.m1_en_US_dedes.heAU.TonOuranionTagmaton.incipit
meVE.SticTheotokion.text = he.a.m1_en_US_dedes.heAU.TonOuranionTagmaton.text

meVE.SticStavrotheotokion.mode = miscellanea_en_US_dedes.misc.Mode1
meVE.SticStavrotheotokion.greekmelody = he.a.m1_en_US_dedes.heAU.TonOuranionTagmaton.greekname
meVE.SticStavrotheotokion.melody = he.a.m1_en_US_dedes.heAU.TonOuranionTagmaton.name
meVE.SticStavrotheotokion.incipit = "When You, O Savior, the…"
meVE.SticStavrotheotokion.text = "When You, O Savior, the lamb and shepherd, were crucified, * Your pure and Virgin Mother, O my God, was there watching. * She cried out in her grief, and she said, “O my Child, * sweetest light of the universe, * who can I watch You be stretched out upon a cross, * as if You were but a criminal?”"

