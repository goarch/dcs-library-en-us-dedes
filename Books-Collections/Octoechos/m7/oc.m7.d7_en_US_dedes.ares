ocLI.Beatitudes1.mode = miscellanea_en_US_dedes.misc.Mode7
ocLI.Beatitudes1.melody = ""
ocLI.Beatitudes1.incipit = oc.m7.d1_en_US_dedes.ocLI.Beatitudes1.incipit
ocLI.Beatitudes1.text = oc.m7.d1_en_US_dedes.ocLI.Beatitudes1.text

ocLI.Beatitudes2.mode = miscellanea_en_US_dedes.misc.Mode7
ocLI.Beatitudes2.melody = ""
ocLI.Beatitudes2.incipit = "O holy Athletes, when you…"
ocLI.Beatitudes2.text = "O holy Athletes, when you had finished * fighting the good fight and kept the faith, * from God you were awarded the crowns * of incorruption and granted * to be glorified with Him, * O all-lauded Martyr Saints, dwelling with the Angels on high."

ocLI.Beatitudes3.mode = miscellanea_en_US_dedes.misc.Mode7
ocLI.Beatitudes3.melody = ""
ocLI.Beatitudes3.incipit = "Let us now honor the…"
ocLI.Beatitudes3.text = "Let us now honor the sacred roster * of the saintly bishops, priests, and monks, * and prophets, holy women, and the rest * who reside in the dwellings * of the first-born now with joy, * socializing with the hosts * of the Incorporeals."

ocLI.Beatitudes4.mode = miscellanea_en_US_dedes.misc.Mode7
ocLI.Beatitudes4.melody = ""
ocLI.Beatitudes4.incipit = "Assign a place wherein dwell…"
ocLI.Beatitudes4.text = "Assign a place wherein dwell the Righteous * to those whom You translated from us, * and overlook the spiritual sins * that they may have committed * in ignorance or knowingly * while on earth, O Word of God, * in Your love and great mercy."

ocLI.BeatitudesTr.mode = miscellanea_en_US_dedes.misc.Mode7
ocLI.BeatitudesTr.melody = ""
ocLI.BeatitudesTr.incipit = "Those who have died supplicate…"
ocLI.BeatitudesTr.text = "Those who have died supplicate You, praying * to You, the all-holy Trinity, * imploring that You save them from that flame * that is fearful and eternal, * and on Judgment Day that they * obtain the eternal goods * and Your holy glory, O God."

ocLI.BeatitudesT.mode = miscellanea_en_US_dedes.misc.Mode7
ocLI.BeatitudesT.melody = ""
ocLI.BeatitudesT.incipit = "All-holy Lady, the Father’s brightness…"
ocLI.BeatitudesT.text = "All-holy Lady, the Father’s brightness * made His dwelling in your virgin womb, * for us who were subjected to the foe * and fell into corruption, * for we took the bad advice. * But, O all-immaculate, * your Son made us new again."

ocLI.MM.Beatitudes1234TrTas78910GB.text = properties_en_US_dedes.media.key

