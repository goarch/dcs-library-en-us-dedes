ocVE.Stichera4.mode = miscellanea_en_US_dedes.misc.Mode7
ocVE.Stichera4.greekmelody = he.a.m7_en_US_dedes.heAU.OukEtiKolyometha.greekname
ocVE.Stichera4.melody = he.a.m7_en_US_dedes.heAU.OukEtiKolyometha.name
ocVE.Stichera4.incipit = "When You return, O Savior…"
ocVE.Stichera4.text = "When You return, O Savior, to judge the whole world, * though I have committed most shameful actions, * put me not to shame, I pray."

