octrMA.Kathisma14.mode = miscellanea_en_US_dedes.misc.Mode7
octrMA.Kathisma14.melody = ""
octrMA.Kathisma14.incipit = "O benevolent Lord…"
octrMA.Kathisma14.text = "O benevolent Lord, grant rest in the land of the living and in the dwellings of the righteous, to Your servants, whose memorial we observe today. As the merciful and forgiving God, forgive any transgressions they may have committed while alive, and grant to the world the great mercy."

