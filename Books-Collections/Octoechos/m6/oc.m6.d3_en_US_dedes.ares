ocVE.Aposticha3.mode = miscellanea_en_US_dedes.misc.Mode6
ocVE.Aposticha3.melody = ""
ocVE.Aposticha3.incipit = "They who witnessed for You…"
ocVE.Aposticha3.text = "They who witnessed for You, O Christ, endured many tortures, and in heaven finally received the crown of glory, that they might intercede on behalf of our souls."

ocVE.AposTheotokion.mode = miscellanea_en_US_dedes.misc.Mode6
ocVE.AposTheotokion.melody = ""
ocVE.AposTheotokion.incipit = "You are a turning…"
ocVE.AposTheotokion.text = "You are a turning for the better for those in trouble and deliverance of the sick, O Virgin Theotokos. Save your people and your flock, since you are the peace of the embattled, tranquil calm of those in agitation, and the believers’ only patronage."

