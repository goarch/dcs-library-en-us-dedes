ocMA.Kathisma32.mode = miscellanea_en_US_dedes.misc.Mode6
ocMA.Kathisma32.greekmelody = he.a.m6_en_US_dedes.heAU.AngelikaiDynameis.greekname
ocMA.Kathisma32.melody = he.a.m6_en_US_dedes.heAU.AngelikaiDynameis.name
ocMA.Kathisma32.incipit = "The martyr athletes offered resistance…"
ocMA.Kathisma32.text = "The martyr athletes offered resistance in the ring, * contesting for the faith, and the tyrants tortured them. * The hosts of Incorporeals observed and were holding the victory medals. * The truly wise contestants amazed the tyrants and kings. * They overturned the devil by their confession of Christ. * O Lord, who strengthened them, glory to You."

ocMA.Kathisma33.mode = miscellanea_en_US_dedes.misc.Mode6
ocMA.Kathisma33.greekmelody = he.a.m6_en_US_dedes.heAU.ElpisTouKosmouAgathi.greekname
ocMA.Kathisma33.melody = he.a.m6_en_US_dedes.heAU.ElpisTouKosmouAgathi.name
ocMA.Kathisma33.incipit = "O Theotokos, my offenses are…"
ocMA.Kathisma33.text = "O Theotokos, my offenses are indeed very many. * To you I run, O Maiden pure, and I pray for salvation. * Visit my infirm and ailing soul, * and pray for me to your Son and our God, * to grant to me forgiveness for the evils I have done, O only blessed Lady."

