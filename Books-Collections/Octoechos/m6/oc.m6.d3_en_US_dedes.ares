ocVE.Stichera1.mode = miscellanea_en_US_dedes.misc.Mode6
ocVE.Stichera1.greekmelody = he.a.m6_en_US_dedes.heAU.OlinApothemenoi.greekname
ocVE.Stichera1.melody = he.a.m6_en_US_dedes.heAU.OlinApothemenoi.name
ocVE.Stichera1.incipit = "…"
ocVE.Stichera1.text = ""

ocVE.Stichera2.mode = miscellanea_en_US_dedes.misc.Mode6
ocVE.Stichera2.melody = he.a.m6_en_US_dedes.heAU.OlinApothemenoi.name
ocVE.Stichera2.incipit = "Who will keep my soul…"
ocVE.Stichera2.text = "Who will keep my soul immune to every harm and temptation; * and who will deliver me * from this death, and namely this sordid flesh of mine? * For when it feels at ease * then it tyrannizes * and it rises up against the soul. * And it afflicts again * when it is infirm. Woe is me, the wretch! * And then, O Savior, I am not able to endure its infirmity. * Hence, O my Creator, * I earnestly entreat, let not the dust * defeat the spirit which into me * You were pleased to breathe in me."

ocVE.Stichera3.mode = miscellanea_en_US_dedes.misc.Mode6
ocVE.Stichera3.melody = he.a.m6_en_US_dedes.heAU.OlinApothemenoi.name
ocVE.Stichera3.incipit = "…"
ocVE.Stichera3.text = ""

ocVE.Stichera4.mode = miscellanea_en_US_dedes.misc.Mode6
ocVE.Stichera4.greekmelody = he.a.m6_en_US_dedes.heAU.IApegnosmeni.greekname
ocVE.Stichera4.melody = he.a.m6_en_US_dedes.heAU.IApegnosmeni.name
ocVE.Stichera4.incipit = "…"
ocVE.Stichera4.text = ""

ocVE.Stichera5.mode = miscellanea_en_US_dedes.misc.Mode6
ocVE.Stichera5.melody = he.a.m6_en_US_dedes.heAU.IApegnosmeni.name
ocVE.Stichera5.incipit = "Totally condemned am I by…"
ocVE.Stichera5.text = "Totally condemned am I by my vices. * I am sunk completely in desperation. * Yes, I am extremely bad in every way and gloomy, * covered with blemishes all over, * entirely corrupted * woefully by unseemly pleasures, * and through abuse am worthless. * I fall prostrate at your feet and beg you, * O blessed John, reject me not, but rather rescue me, * O friend and Forerunner of the Lord."

ocVE.Stichera6.mode = miscellanea_en_US_dedes.misc.Mode6
ocVE.Stichera6.melody = he.a.m6_en_US_dedes.heAU.IApegnosmeni.name
