octrMA.Kathisma11.mode = miscellanea_en_US_dedes.misc.Mode6
octrMA.Kathisma11.melody = ""
octrMA.Kathisma11.incipit = "O Lord, grant me the…"
octrMA.Kathisma11.text = "O Lord, grant me the vigilance of those prudent virgins, and make the lamp of my soul shine, with the oil of Your tender mercies, so that I may sing to You the Angels’ hymn: Alleluia."

