ocLI.Beatitudes1.mode = miscellanea_en_US_dedes.misc.Mode6
ocLI.Beatitudes1.melody = he.h.m6_en_US_dedes.heHE.IToChaireDiAngelou.name
ocLI.Beatitudes1.incipit = oc.m6.d1_en_US_dedes.ocLI.Beatitudes1.incipit
ocLI.Beatitudes1.text = oc.m6.d1_en_US_dedes.ocLI.Beatitudes1.text

ocLI.Beatitudes2.mode = miscellanea_en_US_dedes.misc.Mode6
ocLI.Beatitudes2.melody = he.h.m6_en_US_dedes.heHE.IToChaireDiAngelou.name
ocLI.Beatitudes2.incipit = "You accepted Peter’s weeping in…"
ocLI.Beatitudes2.text = "You accepted Peter’s weeping in repentance. * Please accept my repentance as well, O Christ. * Put me together with those who are being saved."

ocLI.Beatitudes3.mode = miscellanea_en_US_dedes.misc.Mode6
ocLI.Beatitudes3.melody = he.h.m6_en_US_dedes.heHE.IToChaireDiAngelou.name
ocLI.Beatitudes3.incipit = "Holy Forerunner and Baptist of…"
ocLI.Beatitudes3.text = "Holy Forerunner and Baptist of the Savior, * as the herald of repentance to all mankind, * earnestly pray that I repent wholeheartedly."

ocLI.Beatitudes4.mode = miscellanea_en_US_dedes.misc.Mode6
ocLI.Beatitudes4.melody = he.h.m6_en_US_dedes.heHE.IToChaireDiAngelou.name
ocLI.Beatitudes4.incipit = "You endured the painful suffering…"
ocLI.Beatitudes4.text = "You endured the painful suffering of torture, * O victorious Martyrs; and now you cure * mankind’s diseases. Therefore you are praised by all."

ocLI.BeatitudesTr.mode = miscellanea_en_US_dedes.misc.Mode6
ocLI.BeatitudesTr.melody = he.h.m6_en_US_dedes.heHE.IToChaireDiAngelou.name
ocLI.BeatitudesTr.incipit = "You are glorified, O God…"
ocLI.BeatitudesTr.text = "You are glorified, O God, by all the Prophets, * as the Trinity, simple and unconfused. * Save me, through prayers of Your holy Forerunner."

ocLI.BeatitudesT.mode = miscellanea_en_US_dedes.misc.Mode6
ocLI.BeatitudesT.melody = he.h.m6_en_US_dedes.heHE.IToChaireDiAngelou.name
ocLI.BeatitudesT.incipit = "Lady, you are the dependable…"
ocLI.BeatitudesT.text = "Lady, you are the dependable protection * of believers in trouble. Protect me now. * I am exposed to worldly passions. Save me, I pray."

ocLI.MM.Beatitudes1234TrTas78910GB.text = properties_en_US_dedes.media.key

